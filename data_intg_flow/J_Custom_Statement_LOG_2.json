          "_custom_statements" : "USE DATABASE SNOWFLAKE_LEARNING_DB;\nUSE WAREHOUSE COMPUTE_WH;\nUSE SCHEMA PUBLIC;\n\nCREATE OR REPLACE TABLE PUBLIC.staging_product_data (\n  product_id VARCHAR(50),\n  product_name VARCHAR(100),\n  product_price VARCHAR(50)\n);\n\n-- Step 6: Copy data from stage into staging table\nCOPY INTO PUBLIC.staging_product_data\nFROM @PUBLIC.my_internal_stage/sample_data.csv\nFILE_FORMAT = (FORMAT_NAME = 'csv_file_format')\nON_ERROR = 'CONTINUE'\nPURGE = FALSE;\n\n\n-- Step 8: Create final table with proper data types\nCREATE OR REPLACE TABLE PUBLIC.product_data (\n  product_id INTEGER,\n  product_name VARCHAR(100),\n  product_price DECIMAL(10,2),\n  load_timestamp TIMESTAMP_NTZ DEFAULT CURRENT_TIMESTAMP()\n);\n\n-- Step 9: Insert from staging to final table with transformations\nINSERT INTO PUBLIC.product_data (product_id, product_name, product_price)\nSELECT \n  TRY_CAST(product_id AS INTEGER),\n  UPPER(TRIM(product_name)),\n  TRY_CAST(product_price AS DECIMAL(10,2))\nFROM PUBLIC.staging_product_data\nWHERE product_id IS NOT NULL;"

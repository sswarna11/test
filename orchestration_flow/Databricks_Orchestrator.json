            "value" : "#!/bin/bash\nDATABRICKS_URL=\"https://dbc-f8700762-6ef6.cloud.databricks.com\"\nTOKEN=$(cat \"$DATABRICKS_TOKEN\")\nSTATE=\"PENDING\"\n\necho \"Checking Databricks run ID: $DB_RUN_ID\"\n\nwhile [ \"$STATE\" != \"TERMINATED\" ]; do\n  sleep 30\n  RESPONSE=$(curl -s -X GET \\\n    -H \"Authorization: Bearer $TOKEN\" \\\n    \"$DATABRICKS_URL/api/2.1/jobs/runs/get?run_id=$DB_RUN_ID\")\n    STATE=$(echo \"$RESPONSE\" | jq -r '.state.life_cycle_state // \"UNKNOWN\"')\n  echo \"Current state: $STATE\"\ndone\n\nRESULT=$(echo \"$RESPONSE\" | jq -r '.state.result_state // \"UNKNOWN\"')\n  \n\necho \"Final Databricks Result: $RESULT\"\n\nif [ \"$RESULT\" == \"SUCCESS\" ]; then\n  echo \"Databricks job completed successfully!\"\n  exit 0\nelse\n  echo \"Databricks job failed!\"\n  exit 1\nfi"
